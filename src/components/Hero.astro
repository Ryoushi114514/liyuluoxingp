
---
const { title, subtitle, img } = Astro.props;
---
<section class="relative bg-cover bg-center min-h-screen flex items-center justify-center" style={`background-image:url(${img})`}>
  <div class="text-center text-white backdrop-blur-sm p-6 rounded">
    <h1 class="text-5xl font-bold">{title}</h1>
    <p class="mt-4 text-xl">{subtitle}</p>
  </div>
</section>
